<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="25.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.student.lab6.MainController"
      style="-fx-background-color: #f0f4f8;">
    
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>
    
    <Label text="Student Navigator" 
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    
    <Label text="Variant 18 - Laboratory Work 6"
           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
    
    <Separator prefWidth="250"/>
    
    <GridPane hgap="15.0" vgap="15.0" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints prefWidth="120"/>
            <ColumnConstraints prefWidth="180"/>
        </columnConstraints>
        
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-font-size: 14px;"/>
        <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                   promptText="Enter username"/>
        
        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-font-size: 14px;"/>
        <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       promptText="Enter password"/>
    </GridPane>
    
    <HBox alignment="CENTER" spacing="15.0">
        <Button text="Login" onAction="#onLoginButton"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>
        <Button text="Clear" onAction="#onClearButton"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>
        <Button text="Exit" onAction="#onExitButton"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>
    </HBox>
    
    <Label fx:id="messageLabel" 
           style="-fx-font-size: 13px;"
           wrapText="true"
           maxWidth="280"/>
    
    <VBox.margin>
        <Insets top="20.0"/>
    </VBox.margin>
</VBox>

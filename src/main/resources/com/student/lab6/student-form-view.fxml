<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.student.lab6.StudentFormController"
      style="-fx-background-color: #f9f9f9;">
    
    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0"/>
    </padding>
    
    <Label text="Student Information" 
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    
    <Separator prefWidth="300"/>
    
    <GridPane hgap="15.0" vgap="15.0" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints prefWidth="110"/>
            <ColumnConstraints prefWidth="200"/>
        </columnConstraints>
        
        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-font-size: 13px;"/>
        <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                   promptText="Enter student ID"/>
        
        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-font-size: 13px;"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                   promptText="Enter full name"/>
        
        <Label text="Group:" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-font-size: 13px;"/>
        <TextField fx:id="groupField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                   promptText="e.g., ПИ-201"/>
        
        <Label text="Rating (0-5):" GridPane.columnIndex="0" GridPane.rowIndex="3"
               style="-fx-font-size: 13px;"/>
        <TextField fx:id="ratingField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                   promptText="e.g., 4.5"/>
        
        <Label text="Birth Date:" GridPane.columnIndex="0" GridPane.rowIndex="4"
               style="-fx-font-size: 13px;"/>
        <DatePicker fx:id="birthDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="4"
                    promptText="Select date"/>
    </GridPane>
    
    <HBox alignment="CENTER" spacing="15.0">
        <Button text="Save" onAction="#onSaveButton"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 25;"/>
        <Button text="Cancel" onAction="#onCancelButton"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 25;"/>
    </HBox>
    
    <Label fx:id="messageLabel" 
           style="-fx-font-size: 12px;"
           wrapText="true"
           maxWidth="280"/>
</VBox>
